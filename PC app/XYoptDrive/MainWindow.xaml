<Window x:Class="XYoptDrive.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="XY Optical Drive — Device Manager"
        Height="720" Width="860"
        MinHeight="550" MinWidth="650"
        WindowStartupLocation="CenterScreen"
        Background="#1e1e1e" Foreground="#e0e0e0">

    <Window.Resources>
        <Style TargetType="Button" x:Key="ActionButton">
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="#2d2d2d"/>
            <Setter Property="Foreground" Value="#e0e0e0"/>
            <Setter Property="BorderBrush" Value="#404040"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="#2d2d2d"/>
            <Setter Property="Foreground" Value="#e0e0e0"/>
            <Setter Property="BorderBrush" Value="#404040"/>
            <Setter Property="CaretBrush" Value="#e0e0e0"/>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#252525"/>
            <Setter Property="Foreground" Value="#e0e0e0"/>
            <Setter Property="BorderBrush" Value="#404040"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#2d2d2d"/>
            <Setter Property="Foreground" Value="#e0e0e0"/>
            <Setter Property="BorderBrush" Value="#404040"/>
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="#e0e0e0"/>
            <Setter Property="BorderBrush" Value="#404040"/>
        </Style>
        <Style TargetType="Separator">
            <Setter Property="Background" Value="#404040"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*" MinHeight="120"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*" MinHeight="100"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ===== HEADER ===== -->
        <TextBlock Grid.Row="0" Text="Configured Arduino Devices"
                   FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>

        <!-- ===== DEVICE LIST ===== -->
        <DataGrid Grid.Row="1" x:Name="DeviceGrid"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Single" CanUserAddRows="False"
                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                  AlternatingRowBackground="#2a2a2a"
                  Margin="0,0,0,8"
                  MouseDoubleClick="DeviceGrid_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="Role" Binding="{Binding Role}" Width="*"/>
                <DataGridTextColumn Header="IP Address" Binding="{Binding IpAddress}" Width="160"/>
                <DataGridTextColumn Header="Status" Binding="{Binding StatusText}" Width="110"/>
                <DataGridTextColumn Header="Details" Binding="{Binding StatusInfo}" Width="200"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- ===== DEVICE ACTION BUTTONS ===== -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,12">
            <Button Content="🔍 Test Connection" x:Name="BtnTest"
                    Click="BtnTest_Click" Style="{StaticResource ActionButton}"/>
            <Button Content="🔄 Refresh All" x:Name="BtnRefreshAll"
                    Click="BtnRefreshAll_Click" Style="{StaticResource ActionButton}"/>
        </StackPanel>

        <!-- ===== ADD DEVICE FORM ===== -->
        <GroupBox Grid.Row="3" Header="Add a Device" Padding="8" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Name:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox   Grid.Column="1" x:Name="TxtName" Margin="0,0,12,0"/>

                <TextBlock Grid.Column="2" Text="Role:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox   Grid.Column="3" x:Name="TxtRole" Margin="0,0,12,0"/>

                <TextBlock Grid.Column="4" Text="IP:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox   Grid.Column="5" x:Name="TxtIp" Margin="0,0,12,0"/>

                <Button    Grid.Column="6" Content="➕ Add" x:Name="BtnAdd"
                           Click="BtnAdd_Click" Style="{StaticResource ActionButton}"/>
            </Grid>
        </GroupBox>

        <!-- ===== SEPARATOR ===== -->
        <Separator Grid.Row="4" Margin="0,0,0,8"/>

        <!-- ===== NETWORK SCAN SECTION ===== -->
        <Grid Grid.Row="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock Text="Network Scan" FontSize="16" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="0,0,16,0"/>
                <TextBlock Text="Subnet:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox   x:Name="TxtSubnet" Width="160" Margin="0,0,10,0"/>
                <Button Content="📡 Scan" x:Name="BtnScan"
                        Click="BtnScan_Click" Style="{StaticResource ActionButton}"/>
                <Button Content="⛔ Cancel" x:Name="BtnCancelScan"
                        Click="BtnCancelScan_Click" Style="{StaticResource ActionButton}"
                        IsEnabled="False"/>
            </StackPanel>

            <ProgressBar Grid.Row="1" x:Name="ScanProgress" Height="18"
                         Minimum="0" Maximum="100" Margin="0,0,0,8"
                         Visibility="Collapsed" Background="#2d2d2d" Foreground="#4CAF50"/>

            <ListBox Grid.Row="2" x:Name="ScanResultsList" Margin="0,0,0,4"
                     Background="#252525" Foreground="#e0e0e0" BorderBrush="#404040">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding IpAddress}" Width="160"
                                       FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Info}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <!-- ===== BOTTOM BAR ===== -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0">
            <Button Content="➕ Add Selected from Scan" x:Name="BtnAddFromScan"
                    Click="BtnAddFromScan_Click" Style="{StaticResource ActionButton}"/>
            <TextBlock x:Name="TxtStatus" VerticalAlignment="Center" Foreground="Gray"
                       Margin="12,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>
